var MyQueue = function() {
    this.s1=[];
    this.s2=[];
};

MyQueue.prototype.push = function(x) {
    this.s1.push(x)
};

MyQueue.prototype.pop = function() {
    let s1Length=this.s1.length;
    let s2Length=this.s2.length;

    if(s2Length==0){
        for(let i=0;i<s1Length-1;i++){
            this.s2.push(this.s1.pop())
        }
        return this.s1.pop();
    }
    else{
        return this.s2.pop();
    }

};


MyQueue.prototype.peek = function() {
    let s1Length=this.s1.length;
    let s2Length=this.s2.length;

    if(s2Length==0){
        for(let i=0;i<s1Length-1;i++){
            this.s2.push(this.s1.pop())
        }
        let val=this.s1.pop();
        this.s2.push(val)
        return val;
    }
    else{
        let val= this.s2.pop();
        this.s2.push(val)
        return val
    }
};

MyQueue.prototype.empty = function() {
    return this.s1.length===0 && this.s2.length===0;
};

